{
  "name": "<name>",
  "paths": {
    "workspace": "./workspace",
    "sessions": "./sessions"
  },
  "agents": {
    "defaults": {
      "model": "MiniMax-M2.5",
      "fallbackModel": "MiniMax-M2.1",
      "maxTokens": 8192,
      "temperature": 0.7,
      "maxToolIterations": 20,
      "memoryWindow": 50,
      "llmPolicy": {
        "retry": {
          "maxRetries": 4,
          "baseDelaySec": 0.75,
          "maxDelaySec": 8.0,
          "retryableStatusCodes": [408, 409, 429, 500, 502, 503, 504]
        },
        "fallback": {
          "enabled": true,
          "retryableErrorsOnly": true
        }
      }
    }
  },
  "providers": {
    "minimax": {
      "apiKey": "<MINIMAX_API_KEY>",
      "apiBase": "https://api.minimaxi.com/v1",
      "extraHeaders": null
    },
    "openaiCodex": {}
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "appId": "<FEISHU_APP_ID>",
      "appSecret": "<FEISHU_APP_SECRET>",
      "encryptKey": "",
      "verificationToken": "",
      "wikiSpaceId": "",
      "wikiParentNodeToken": "",
      "docWriteAutoChunkThresholdChars": 6000,
      "allowFrom": [
        "<FEISHU_USER_OPEN_ID>:<PHONE_NUMBER>"
      ]
    }
  },
  "tools": {
    "web": {
      "search": {
        "apiKey": "<TAVILY_API_KEY>",
        "maxResults": 5
      }
    },
    "exec": {
      "timeout": 300,
      "pathAppend": "",
      "approvalEnabled": true,
      "approvalRiskLevel": "dangerous",
      "approvalApprovers": []
    },
    "restrictToWorkspace": true
  },
  "skills": {
    "env": {
      "OPENAI_API_KEY": "<OPENAI_API_KEY>",
      "OPENAI_BASE_URL": "https://api.openai.com/v1",
      "VISION_API_KEY": "<NEWAPI_API_KEY>",
      "VISION_BASE_URL": "https://openai.melody.games/v1",
      "VISION_MODEL": "kimi-k2.5",
      "IMAGEGEN_API_URL": "https://openrouter.ai/api/v1/chat/completions",
      "IMAGEGEN_API_KEY": "<OPENROUTER_API_KEY>",
      "IMAGEGEN_MODEL": "bytedance-seed/seedream-4.5",
      "TEXTGEN_API_KEY": "<NEWAPI_API_KEY>",
      "TEXTGEN_BASE_URL": "https://openai.melody.games/v1",
      "TEXTGEN_MODEL": "kimi-k2.5"
    }
  }
}
